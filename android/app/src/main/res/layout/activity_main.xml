<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true"
    android:overScrollMode="never"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="56dp"
        android:paddingBottom="40dp">

        <!-- ═══ Header Row ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="PHONEBRIDGE"
                android:textSize="13sp"
                android:textColor="@color/text_muted"
                android:letterSpacing="0.15"
                android:fontFamily="sans-serif-medium" />

            <!-- Auto-start toggle (compact) -->
            <ImageView
                android:id="@+id/btnAutoStartInfo"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_dialog_info"
                android:contentDescription="Auto-start info"
                android:clickable="true"
                android:focusable="true"
                app:tint="@color/text_hint" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchAutoStart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp" />

        </LinearLayout>

        <!-- ═══ Status Indicator ═══ -->
        <View
            android:id="@+id/statusIndicator"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <!-- ═══ Hero Toggle ═══ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center">

                <!-- Toggle container with glow -->
                <FrameLayout
                    android:layout_width="120dp"
                    android:layout_height="120dp">

                    <!-- Glow ring (behind button, visible when active) -->
                    <View
                        android:id="@+id/viewGlowRing"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_glow_ring"
                        android:visibility="gone" />

                    <!-- Main toggle button -->
                    <ImageButton
                        android:id="@+id/btnToggle"
                        android:layout_width="88dp"
                        android:layout_height="88dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_toggle_inactive"
                        android:src="@drawable/ic_power"
                        android:scaleType="centerInside"
                        android:padding="22dp"
                        android:contentDescription="Toggle Server"
                        app:tint="@color/text_muted"
                        android:elevation="4dp" />

                </FrameLayout>

                <!-- Status text -->
                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap to start"
                    android:textSize="15sp"
                    android:textColor="@color/text_muted"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="16dp" />

            </LinearLayout>
        </FrameLayout>


        <!-- ═══ Connection Card ═══ -->
        <LinearLayout
            android:id="@+id/cardConnection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="24dp"
            android:layout_marginTop="8dp"
            android:elevation="1dp"
            android:gravity="center"
            android:visibility="gone">

            <!-- Connection status row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_toggle_active" />

                <TextView
                    android:id="@+id/tvProtocolBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Secured · HTTPS"
                    android:textSize="12sp"
                    android:textColor="@color/text_muted"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginStart="8dp"
                    android:letterSpacing="0.02" />
            </LinearLayout>

            <!-- Password label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONNECTION CODE"
                android:textSize="11sp"
                android:textColor="@color/text_hint"
                android:letterSpacing="0.15"
                android:fontFamily="sans-serif-medium" />

            <!-- Password display — fits 8 chars on one line -->
            <TextView
                android:id="@+id/tvPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— — — —"
                android:textSize="28sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0.15"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="4dp"
                android:textIsSelectable="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enter this code on your PC"
                android:textSize="12sp"
                android:textColor="@color/text_muted"
                android:layout_marginBottom="16dp" />

            <!-- Button row: Copy + Regenerate -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Copy button -->
                <TextView
                    android:id="@+id/btnCopyPassword"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Copy"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/bg_chip"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="8dp" />

                <!-- Regenerate button -->
                <TextView
                    android:id="@+id/btnRegenPassword"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Regenerate"
                    android:textSize="14sp"
                    android:textColor="@color/text_muted"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/bg_chip"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- Hidden address field (kept for binding compatibility) -->
            <TextView
                android:id="@+id/tvAddress"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

        </LinearLayout>


        <!-- ═══ Stats Grid ═══ -->
        <LinearLayout
            android:id="@+id/cardStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            android:visibility="gone">

            <!-- Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <!-- Uploaded -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="16dp"
                    android:layout_marginEnd="6dp"
                    android:elevation="1dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="↑ Uploaded"
                        android:textSize="11sp"
                        android:textColor="@color/text_muted" />

                    <TextView
                        android:id="@+id/tvBytesReceived"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 B"
                        android:textSize="20sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-light"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

                <!-- Downloaded -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="16dp"
                    android:layout_marginStart="6dp"
                    android:elevation="1dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="↓ Downloaded"
                        android:textSize="11sp"
                        android:textColor="@color/text_muted" />

                    <TextView
                        android:id="@+id/tvBytesServed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 B"
                        android:textSize="20sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-light"
                        android:layout_marginTop="6dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp"
                android:baselineAligned="false">

                <!-- Uptime -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="16dp"
                    android:layout_marginEnd="6dp"
                    android:elevation="1dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Uptime"
                        android:textSize="11sp"
                        android:textColor="@color/text_muted" />

                    <TextView
                        android:id="@+id/tvUptime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00:00:00"
                        android:textSize="20sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="monospace"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

                <!-- Connections -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="16dp"
                    android:layout_marginStart="6dp"
                    android:elevation="1dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Connections"
                        android:textSize="11sp"
                        android:textColor="@color/text_muted" />

                    <TextView
                        android:id="@+id/tvConnections"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="20sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-light"
                        android:layout_marginTop="6dp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvTotalRequests"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 requests"
                android:textSize="11sp"
                android:textColor="@color/text_hint"
                android:layout_marginTop="8dp"
                android:layout_gravity="end" />

        </LinearLayout>

        <!-- ═══ Storage ═══ -->
        <LinearLayout
            android:id="@+id/cardStorage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="20dp"
            android:layout_marginTop="12dp"
            android:elevation="1dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="STORAGE"
                    android:textSize="11sp"
                    android:textColor="@color/text_muted"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvStoragePercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressStorage"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="12dp"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/progress_storage" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/tvStorageUsed"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Used: —"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvStorageTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total: —"
                    android:textSize="12sp"
                    android:textColor="@color/text_muted" />
            </LinearLayout>

        </LinearLayout>

        <!-- ═══ Remote Access Card ═══ -->
        <LinearLayout
            android:id="@+id/cardRemoteAccess"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="20dp"
            android:layout_marginTop="12dp"
            android:elevation="1dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="REMOTE ACCESS"
                    android:textSize="11sp"
                    android:textColor="@color/text_muted"
                    android:letterSpacing="0.1" />

                <!-- Status indicator -->
                <TextView
                    android:id="@+id/tvRemoteStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● Connected"
                    android:textSize="12sp"
                    android:textColor="@color/active_green"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- Tailscale IP available state -->
            <LinearLayout
                android:id="@+id/layoutTailscaleAvailable"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Remote address"
                    android:textSize="12sp"
                    android:textColor="@color/text_muted"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvTailscaleIp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="100.x.y.z:8273"
                    android:textSize="18sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="monospace"
                    android:textIsSelectable="true"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Use this address to connect from any network"
                    android:textSize="11sp"
                    android:textColor="@color/text_hint"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/btnCopyTailscaleIp"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:text="📋 Copy Remote Address"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/bg_chip"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Tailscale not installed state -->
            <LinearLayout
                android:id="@+id/layoutTailscaleNotInstalled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Access your files from anywhere"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Install Tailscale VPN on both devices to connect from any network — no port forwarding needed."
                    android:textSize="12sp"
                    android:textColor="@color/text_muted"
                    android:lineSpacingExtra="2dp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/btnGetTailscale"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:text="Get Tailscale →"
                    android:textSize="13sp"
                    android:textColor="@color/accent"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/bg_chip"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

        </LinearLayout>

        <!-- ═══ Settings ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SETTINGS"
                android:textSize="11sp"
                android:textColor="@color/text_muted"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp" />

            <!-- Shared Folder -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="20dp"
                android:elevation="1dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Shared Folder"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Choose which folder to share"
                    android:textSize="12sp"
                    android:textColor="@color/text_muted"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="14dp" />

                <!-- Folder Chips -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/chipGroupFolders"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/chipAllStorage"
                            android:layout_width="wrap_content"
                            android:layout_height="34dp"
                            android:gravity="center"
                            android:text="All Storage"
                            android:textSize="13sp"
                            android:textColor="@color/bg_card"
                            android:paddingHorizontal="16dp"
                            android:background="@drawable/bg_chip_selected"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/chipDCIM"
                            android:layout_width="wrap_content"
                            android:layout_height="34dp"
                            android:gravity="center"
                            android:text="DCIM"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"
                            android:paddingHorizontal="16dp"
                            android:background="@drawable/bg_chip"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/chipDownloads"
                            android:layout_width="wrap_content"
                            android:layout_height="34dp"
                            android:gravity="center"
                            android:text="Downloads"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"
                            android:paddingHorizontal="16dp"
                            android:background="@drawable/bg_chip"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/chipMusic"
                            android:layout_width="wrap_content"
                            android:layout_height="34dp"
                            android:gravity="center"
                            android:text="Music"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"
                            android:paddingHorizontal="16dp"
                            android:background="@drawable/bg_chip" />
                    </LinearLayout>
                </HorizontalScrollView>

            </LinearLayout>



        </LinearLayout>

        <!-- ═══ Info (when stopped) ═══ -->
        <TextView
            android:id="@+id/tvInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Tap the button to start sharing your phone's storage wirelessly."
            android:textSize="14sp"
            android:textColor="@color/text_muted"
            android:gravity="center"
            android:lineSpacingExtra="4dp" />

        <!-- ═══ Footer ═══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="v0.2.0"
            android:textSize="11sp"
            android:textColor="@color/text_hint"
            android:layout_marginTop="32dp" />

    </LinearLayout>

</ScrollView>
